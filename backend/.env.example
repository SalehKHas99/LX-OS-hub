# ── Database ───────────────────────────────────────────────
# Get this from your Neon dashboard → Connection Details → Connection string
# IMPORTANT: Change "postgresql://" to "postgresql+asyncpg://" in the URL
DATABASE_URL=postgresql+asyncpg://user:password@host.neon.tech/dbname?sslmode=require

# ── Auth ───────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── App ────────────────────────────────────────────────────
ENVIRONMENT=development
# For multiple origins in production: comma-separated, no spaces
# e.g. https://lxos.netlify.app,https://www.lxos.app
CORS_ORIGINS=http://localhost:5173

# ── Anthropic (Context Lab) ────────────────────────────────
# Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase Storage (configure when ready in Phase 6) ─────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
