pgdata/
uploads_local/

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*

# ── Coverage / Test ───────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
coverage/
.nyc_output/

