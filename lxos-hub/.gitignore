# ── Environment ───────────────────────────────────────────────
.env
.env.local
.env.*.local
!.env.example

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
*.pyo
.venv/
venv/
ENV/
.python-version

