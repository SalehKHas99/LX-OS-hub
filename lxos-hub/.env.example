# ══════════════════════════════════════════════════════════════════════════════
# LX-OS Hub — Environment Configuration
# Copy to .env and fill in values before running.
#
# Generate secrets:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# ALWAYS use the POOLER endpoint — not the direct one.
# Format: postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/lxos

# Self-hosted only (docker-compose.prod.yml internal postgres container)
POSTGRES_PASSWORD=change_me_in_production

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Production (Upstash TLS):  rediss://default:TOKEN@global-xxx.upstash.io:6379
# Local dev (bundled redis): redis://redis:6379/0
REDIS_URL=redis://redis:6379/0

# ── Security Secrets ─────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# NEVER change JWT_SECRET after launch — invalidates all password hashes.
JWT_SECRET=dev_jwt_secret_replace_this_in_production_abcdef1234567890abcdef
WEBHOOK_SECRET=dev_webhook_secret_replace_in_production_xyz9876543210xyz9876

# ── CORS + OAuth URLs ─────────────────────────────────────────────────────────
# Your public frontend URL. Sets CORS policy and OAuth redirect base.
# Dev: http://localhost:3000
# Prod: https://your-app.vercel.app  or  https://yourdomain.com
FRONTEND_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins. Must include FRONTEND_URL.
# Dev: http://localhost:3000
# Prod: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend API Base (Next.js build-time variable) ───────────────────────────
# Dev (no nginx):   http://localhost:8000
# Self-hosted prod: /api  (nginx proxies /api/* → api:8000/*)
# Separate domain:  https://api.yourdomain.com
NEXT_PUBLIC_API_BASE=http://localhost:8000

# ── Demo Mode ─────────────────────────────────────────────────────────────────
# true  → unauthenticated requests get owner role (LOCAL DEV ONLY)
# false → unauthenticated requests get read-only guest (REQUIRED in production)
DEMO_MODE=true

# ── LLM Providers (optional) ─────────────────────────────────────────────────
# If both are set, Anthropic is preferred.
# If neither is set, runs use simulated outputs.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Google OAuth (optional) ──────────────────────────────────────────────────
# Enables "Sign in with Google" button on the login page.
# Get from: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must exactly match Authorized redirect URI in Google Console
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback/google

# ── File Uploads ─────────────────────────────────────────────────────────────
# Local filesystem path for uploaded avatars/logos.
# Override with /mnt/uploads for external volume mounts.
UPLOAD_DIR=/app/uploads

# ── Internal Services ─────────────────────────────────────────────────────────
# Internal URL for the API container (used by outbox webhook dispatcher).
# Dev: http://api:8000   Prod: http://api:8000 (same — Docker internal)
WEBHOOK_INTERNAL_BASE=http://api:8000

# ── Vocode Voice Integration (optional) ──────────────────────────────────────
# See integrations/vocode/README.md for setup instructions.
LXOS_HUB_API_BASE=http://localhost:8000
LXOS_HUB_API_KEY=
VOCODE_API_KEY=
