{
  "name": "lxos-hub",
  "displayName": "LX-OS Hub",
  "description": "Browse, run, and lint LX-DSL prompts from VS Code",
  "version": "0.1.0",
  "publisher": "lxos",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR_ORG/lxos-hub"
  },
  "engines": { "vscode": "^1.85.0" },
  "categories": ["AI", "Other"],
  "keywords": ["prompt", "LLM", "AI", "DSL", "benchmark"],
  "icon": "media/icon.png",
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "LX-OS Hub",
      "properties": {
        "lxosHub.apiBase": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "LX-OS Hub API base URL"
        },
        "lxosHub.apiKey": {
          "type": "string",
          "default": "",
          "description": "Session token or API key (lxos_sess_... or raw API key)"
        },
        "lxosHub.autoLint": {
          "type": "boolean",
          "default": true,
          "description": "Automatically lint .lxdsl and .yaml files with Hub suggestions engine"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lxos-hub",
          "title": "LX-OS Hub",
          "icon": "media/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "lxos-hub": [
        { "id": "lxosHub.promptLibrary", "name": "Prompt Library" },
        { "id": "lxosHub.recentRuns",    "name": "Recent Runs" },
        { "id": "lxosHub.benchmarks",    "name": "Benchmarks" }
      ]
    },
    "commands": [
      {
        "command": "lxosHub.runPrompt",
        "title": "LX-OS Hub: Run Prompt",
        "icon": "$(play)"
      },
      {
        "command": "lxosHub.lintDsl",
        "title": "LX-OS Hub: Lint DSL",
        "icon": "$(lightbulb)"
      },
      {
        "command": "lxosHub.openInHub",
        "title": "LX-OS Hub: Open in Browser"
      },
      {
        "command": "lxosHub.refreshLibrary",
        "title": "LX-OS Hub: Refresh Library",
        "icon": "$(refresh)"
      },
      {
        "command": "lxosHub.setApiKey",
        "title": "LX-OS Hub: Set API Key / Session Token"
      },
      {
        "command": "lxosHub.createPrompt",
        "title": "LX-OS Hub: Create New Prompt from Selection"
      },
      {
        "command": "lxosHub.forkPrompt",
        "title": "LX-OS Hub: Fork this Prompt"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceExtname == .yaml || resourceExtname == .lxdsl",
          "command": "lxosHub.runPrompt",
          "group": "lxos@1"
        },
        {
          "when": "resourceExtname == .yaml || resourceExtname == .lxdsl",
          "command": "lxosHub.lintDsl",
          "group": "lxos@2"
        },
        {
          "when": "editorHasSelection",
          "command": "lxosHub.createPrompt",
          "group": "lxos@3"
        }
      ],
      "view/title": [
        {
          "command": "lxosHub.refreshLibrary",
          "when": "view == lxosHub.promptLibrary",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "lxdsl",
        "aliases": ["LX-DSL", "lxdsl"],
        "extensions": [".lxdsl"],
        "mimetypes": ["text/x-lxdsl"]
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npm run compile && npx @vscode/vsce package",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "typescript": "5.4.5"
  }
}
